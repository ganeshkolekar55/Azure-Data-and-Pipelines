				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": "Customers (1).csv",
						"fileSystem": "source"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
